# Clave secreta para firmar y validar los JSON Web Tokens (JWT)
JWT_SECRET="yamboly_mvp_super_secret_2026_change_me_in_prod"

# Origen permitido para solicitudes CORS (dominio del frontend)
CORS_ORIGIN="http://localhost:80"

# =========================================================================
# CONFIGURACIÓN DEL FRONTEND (VITE BUILD ARGS)
